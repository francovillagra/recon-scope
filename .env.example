# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Compose (postgres service):
DATABASE_URL=postgresql+asyncpg://recon:recon@localhost:5432/recon

# Supabase (production) — use the "Session pooler" connection string and
# replace the scheme: postgresql:// → postgresql+asyncpg://
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Engine (FastAPI / Python) ──────────────────────────────────────────────────
PORT=8000
DEBUG=false

# HS256 secret — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-in-production
JWT_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12

# Comma-separated list of allowed CORS origins (JSON array as string)
CORS_ORIGINS=["http://localhost:3000"]

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Local Postgres (docker-compose only) ─────────────────────────────────────
POSTGRES_USER=recon
POSTGRES_PASSWORD=recon
POSTGRES_DB=recon
